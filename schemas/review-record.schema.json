{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Content Review Record",
  "type": "object",
  "required": [
    "page",
    "reviewer",
    "review_date",
    "decision"
  ],
  "properties": {
    "page": {
      "type": "string"
    },
    "reviewer": {
      "type": "string"
    },
    "review_date": {
      "type": "string"
    },
    "decision": {
      "type": "string",
      "enum": [
        "keep-draft",
        "reviewed",
        "published",
        "archive"
      ]
    },
    "notes": {
      "type": "string"
    }
  }
}
